<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.youthhealth.modules.analytics.mapper.AdviceMapper">

    <resultMap id="adviceLogResultMap" type="com.youthhealth.modules.analytics.entity.AdviceLog">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="energyAdvice" column="energy_advice"/>
        <result property="dietAdvice" column="diet_advice"/>
        <result property="sportAdvice" column="sport_advice"/>
        <result property="adviceText" column="advice_text"/>
        <result property="summaryJson" column="summary_json"/>
        <result property="sourceType" column="source_type"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.youthhealth.modules.analytics.entity.AdviceLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO advice_log
        (user_id, energy_advice, diet_advice, sport_advice, advice_text, summary_json, source_type)
        VALUES
        (#{userId}, #{energyAdvice}, #{dietAdvice}, #{sportAdvice}, #{adviceText}, #{summaryJson}, #{sourceType})
    </insert>

    <select id="findLatestByUserId" resultMap="adviceLogResultMap">
        SELECT id, user_id, energy_advice, diet_advice, sport_advice, advice_text, summary_json, source_type, created_at
        FROM advice_log
        WHERE user_id = #{userId}
        ORDER BY id DESC
        LIMIT 1
    </select>

</mapper>
